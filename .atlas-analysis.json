  "keyFeatures": [
    "Default-deny security model — commands, filesystem, environment, and redirections all blocked by default",
    "AllowedCommands with namespaced rshell: prefix prevents command injection",
    "AllowedPaths filesystem sandboxing using Go os.Root (openat syscalls), immune to symlink traversal and TOCTOU attacks",
    "20+ built-in POSIX commands (cat, grep, find, sed, ls, ps, ss, ping, etc.) with security restrictions applied",
    "Whole-run execution timeout via context or MaxExecutionTime option",
    "Cross-platform: Linux, macOS, and Windows",
    "900+ YAML-driven test scenarios validated against real bash for POSIX parity",
    "Embeddable as a Go library or usable as a standalone CLI binary"
  ],
  "publicApiSurface": [
    "interp.New(opts ...RunnerOption) (*Runner, error)",
    "interp.Runner.Run(ctx context.Context, node syntax.Node) error",
    "interp.Runner.Reset()",
    "interp.Runner.Close() error",
    "interp.StdIO(in io.Reader, out, err io.Writer) RunnerOption",
    "interp.Env(pairs ...string) RunnerOption",
    "interp.AllowedCommands(names []string) RunnerOption",
    "interp.AllowAllCommands() RunnerOption",
    "interp.AllowedPaths(paths []string) RunnerOption",
    "interp.MaxExecutionTime(d time.Duration) RunnerOption",
    "interp.ProcPath(path string) RunnerOption",
    "interp.ExitStatus",
